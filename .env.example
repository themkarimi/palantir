# Admin credentials (stored server-side only — never sent to client)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# JWT secret — generate with: openssl rand -base64 32
# Must be at least 32 characters
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long

# Path to the apps data file (relative to project root)
DATA_FILE_PATH=./data/apps.json

# ──────────────────────────────────────────────────────────────────────────────
# OIDC / SSO Authentication (optional)
# When all four OIDC_* variables are set, a "Sign in with SSO" button appears
# on the login page. Compatible with Keycloak and any standard OIDC provider.
# ──────────────────────────────────────────────────────────────────────────────

# Issuer URL of your OIDC provider (the realm base URL for Keycloak)
# OIDC_ISSUER=https://keycloak.example.com/realms/my-realm

# Client ID registered in the OIDC provider
# OIDC_CLIENT_ID=palantir

# Client secret (use a confidential client)
# OIDC_CLIENT_SECRET=your-client-secret

# Absolute URL of the callback endpoint — must be registered as a valid redirect URI
# in the OIDC provider (e.g. Keycloak → Client → Valid Redirect URIs)
# OIDC_REDIRECT_URI=https://palantir.example.com/api/auth/oidc/callback

# Group name from the OIDC provider that grants admin access.
# Keycloak includes group membership in the `groups` claim (e.g. /admins).
# Both "/admins" and "admins" are accepted. Leave unset to allow any
# authenticated OIDC user to access the admin area.
# OIDC_ADMIN_GROUP=palantir-admins

# Space-separated scopes to request (default shown below).
# Make sure your Keycloak client / scope mapper exposes the `groups` claim.
# OIDC_SCOPES=openid profile email groups
